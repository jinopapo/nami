{
  "name": "nami",
  "version": "0.1.0",
  "private": true,
  "description": "React + TypeScript + Electron starter",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"npm run dev:electron:watch\" \"npm run dev:electron:start\"",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch",
    "dev:electron:start": " electron .",
    "build": "npm run build:renderer && npm run build:electron && npm run package:mac",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package:mac": "electron-builder --mac dir",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "detect-unused-code:renderer": "ts-prune -p tsconfig.json --error",
    "detect-unused-code:electron": "ts-prune -p tsconfig.electron.json --error",
    "detect-unused-code": "npm run detect-unused-code:renderer && npm run detect-unused-code:electron",
    "lint": "eslint . --fix && npm run lint:ast-grep",
    "lint:ast-grep": "ast-grep scan --config sgconfig.yml --error",
    "test:ast-grep": "ast-grep test --config sgconfig.yml --skip-snapshot-tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --reporter=agent",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-react": "^4.4.1",
    "cline": "^2.8.0",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.23.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "ts-prune": "^0.10.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.jinopapo.nami",
    "productName": "nami",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/preload.cjs",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
